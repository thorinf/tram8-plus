Checks: >
  -*,
  bugprone-*,
  performance-*,
  modernize-use-override,
  modernize-use-nullptr,
  readability-redundant-declaration,
  readability-misleading-indentation,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,

# bugprone-*                        Catches real bugs: use-after-move, dangling handles, etc.
# performance-*                     Unnecessary copies, inefficient containers, move semantics
# modernize-use-override/nullptr    Low noise, prevents real mistakes
# readability-redundant-*           Dead declarations
# readability-misleading-indent     Catches indentation bugs
#
# Disabled:
# bugprone-easily-swappable-params  Too noisy for MIDI/gate functions (uint8_t channel, uint8_t note, uint8_t velocity)
# bugprone-narrowing-conversions    Noisy with AVR/MIDI code (int/uint8_t conversions everywhere)

HeaderFilterRegex: '(firmware/src|vst/source|protocol)/.*\.(h|hpp)$'

WarningsAsErrors: ''
